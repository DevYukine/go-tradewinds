# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=tradewinds
DB_PASSWORD=secret
DB_NAME=tradewinds
DB_SSLMODE=disable

# Game API
BOT_BASE_URL=https://tradewinds.fly.dev
API_PORT=3002

# Single game account
PLAYER_EMAIL=player@example.com
PLAYER_PASSWORD=secretpass

# Strategy allocation — strategy_name:company_count
# Total companies must fit within rate limit budget (auto-capped if too many)
STRATEGY_ALLOCATION=arbitrage:3,bulk_hauler:2,market_maker:2

# Rate limit: 300 req/60s per IP (game spec). Override only if changed.
# RATE_LIMIT_PER_MINUTE=300

# AI Agent configuration (default for all companies)
AGENT_TYPE=heuristic
# LLM_PROVIDER=claude
# LLM_MODEL=claude-sonnet-4-6
# LLM_API_KEY=sk-ant-...
# LLM_MAX_TOKENS=4096
# COMPOSITE_FAST_AGENT=heuristic
# COMPOSITE_SLOW_AGENT=llm

# Per-provider API keys (for multi-LLM setups)
# CLAUDE_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# Mixed allocation example (7 heuristic + 3 LLM companies via OpenRouter):
# STRATEGY_ALLOCATION=arbitrage:3,bulk_hauler:2,market_maker:2,arbitrage/llm-openrouter:1,bulk_hauler/llm-openrouter:1,market_maker/llm-openrouter:1
